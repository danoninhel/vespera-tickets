{
  "name": "vespera-tickets-backend",
  "version": "1.0.0",
  "description": "Backend serverless para venda de ingressos (Vespera)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "watch": "tsc --watch",
    "serve": "serverless offline",
    "start": "node --import tsx serverless-offline.ts",
    "dev": "node --import tsx serverless-offline.ts",
    "deploy": "serverless deploy",
    "test": "vitest --run"
  },

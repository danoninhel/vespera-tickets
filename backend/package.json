    "@types/pg": "^8.20.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.27.7",
    "prisma": "^7.7.0",
    "serverless-esbuild": "^1.57.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "dotenv": "^17.4.1",
    "mercadopago": "^1.1.1",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0",
    "resend": "^4.8.0",

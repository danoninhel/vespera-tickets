generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model artists {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  event_artists event_artists[]
}

model event_artists {
  event_id  String  @db.Uuid
  artist_id String  @db.Uuid
  artists   artists @relation(fields: [artist_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  events    events  @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([event_id, artist_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model events {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String
  description   String?
  image_url     String?
  capacity      Int
  metadata      Json?           @default("{}")
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  event_artists event_artists[]
  lotes         lotes[]
  orders        orders[]
  tickets       tickets[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model lotes {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id   String    @db.Uuid
  name       String
  price      Int
  total      Int
  reserved   Int       @default(0)
  position   Int
  created_at DateTime? @default(now()) @db.Timestamp(6)
  events     events    @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([event_id], map: "idx_lotes_event")
  @@index([event_id, position], map: "idx_lotes_event_position")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model orders {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id        String    @db.Uuid
  status          String
  ticket_quantity Int
  expires_at      DateTime  @db.Timestamp(6)
  payment_id      String?   @unique
  created_at      DateTime? @default(now()) @db.Timestamp(6)
  events          events    @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tickets         tickets[]

  @@index([event_id], map: "idx_orders_event")
  @@index([status], map: "idx_orders_status")
}

model tickets {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_id   String    @db.Uuid
  order_id   String    @db.Uuid
  name       String
  email      String
  created_at DateTime? @default(now()) @db.Timestamp(6)
  events     events    @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  orders     orders    @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([event_id], map: "idx_tickets_event")
  @@index([order_id], map: "idx_tickets_order")
}
